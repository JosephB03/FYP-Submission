<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/analyticsOverlay"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="#99000000"
    android:visibility="gone">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ANALYTICS"
        android:textColor="#00FF00"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        android:layout_marginBottom="6dp" />

    <!-- DR Position -->
    <TextView
        android:id="@+id/analyticsDRPosition"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DR: ---, ---"
        android:textColor="#DDDDDD"
        android:textSize="10sp"
        android:fontFamily="monospace" />

    <!-- Heading -->
    <TextView
        android:id="@+id/analyticsHeading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HDG: M--- E--- F---"
        android:textColor="#DDDDDD"
        android:textSize="10sp"
        android:fontFamily="monospace" />

    <!-- Steps -->
    <TextView
        android:id="@+id/analyticsSteps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Steps: 0"
        android:textColor="#DDDDDD"
        android:textSize="10sp"
        android:fontFamily="monospace" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#44FFFFFF"
        android:layout_marginVertical="4dp" />

    <!-- GPS Confidence -->
    <TextView
        android:id="@+id/analyticsGPSConfidence"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GPS: --- (Acc- Cn0- San- Stal-)"
        android:textColor="#DDDDDD"
        android:textSize="10sp"
        android:fontFamily="monospace" />

    <!-- Satellites -->
    <TextView
        android:id="@+id/analyticsSatellites"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sats: 0  Cn0: --"
        android:textColor="#DDDDDD"
        android:textSize="10sp"
        android:fontFamily="monospace" />

    <!-- GPS Accuracy -->
    <TextView
        android:id="@+id/analyticsGPSAccuracy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GPS Acc: -- m"
        android:textColor="#DDDDDD"
        android:textSize="10sp"
        android:fontFamily="monospace" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#44FFFFFF"
        android:layout_marginVertical="4dp" />

    <!-- Peers -->
    <!-- Peers -->
    <TextView
        android:id="@+id/analyticsPeers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Peers: 0"
        android:textColor="#DDDDDD"
        android:textSize="10sp"
        android:fontFamily="monospace" />

    <TextView
        android:id="@+id/analyticsPeersDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=" trust=0 far=0"
        android:textColor="#AAAAAA"
        android:textSize="8sp"
        android:fontFamily="monospace" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#44FFFFFF"
        android:layout_marginVertical="4dp" />

    <!-- Power Mode -->
    <TextView
        android:id="@+id/analyticsPowerMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mode: NORMAL"
        android:textColor="#DDDDDD"
        android:textSize="10sp"
        android:fontFamily="monospace" />

</LinearLayout>